# Your stable production URL — used when registering QStash schedules
APP_URL=https://your-app.vercel.app

# VAPID keys — generate with:
# node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log('PUBLIC_VAPID_KEY='+k.publicKey+'\nVAPID_PRIVATE_KEY='+k.privateKey)"
PUBLIC_VAPID_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Upstash Redis — from console.upstash.com (create a Redis database)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash — from console.upstash.com (QStash tab)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
